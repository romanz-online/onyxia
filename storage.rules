rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Public read access to release files
    match /releases/{version}/{platform}/{fileName} {
      // Anyone can read/download release files
      allow read: if true;

      // Only authenticated users can write
      allow write: if request.auth != null;
    }

    // User avatars - publicly readable (profile pictures visible to all app users)
    match /users/{uid}/avatars/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // All other files - default rules
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
